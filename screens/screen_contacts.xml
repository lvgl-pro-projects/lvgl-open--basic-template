<!-- CONTACTS: non-permanent screen reached from home via screen_create_event.
     Two-column layout: a contact list on the left, ring/notification
     settings on the right (bound to subject_ringer_volume,
     subject_ring_duration, subject_do_not_disturb, subject_show_photos
     from globals.xml). -->
<screen>
	<view extends="lv_obj">
		<style name="style_screen_light" />
		<bind_style name="style_screen_dark" subject="subject_theme_dark" ref_value="1" />
		<style name="style_scrollbar" selector="scrollbar" />

		<container name="content" width="100%" height="100%" pad="#space_lg" gap="#space_md">
			<h2 text="Contacts" />

			<!-- Two columns sharing the remaining height. -->
			<container width="100%" flow="row" gap="#space_lg" grow="1">
				<!-- LEFT: contact list inside a framed window. -->

				<list flex_grow="1">
					<list_section text="Favorites" />

					<list_item title="Ada Lovelace" subtitle="Mobile · online">
						<list_item-trailing>
							<h5 text="Call">
								<style name="style_text_accent" />
							</h5>
						</list_item-trailing>
					</list_item>

					<list_item title="Alan Turing" subtitle="Work · last seen 1h">
						<list_item-trailing>
							<h5 text="Call">
								<style name="style_text_accent" />
							</h5>
						</list_item-trailing>
					</list_item>

					<list_separator />
					<list_section text="Recent" />

					<list_item title="Grace Hopper" subtitle="Missed call · 12:04" />
					<list_item title="Linus Torvalds" subtitle="Voicemail · yesterday" />
					<list_item title="Margaret Hamilton" subtitle="Mobile · Mon" />
				</list>

				<!-- RIGHT: call/notification settings bound to the contact subjects. -->
				<panel grow="1" gap="#space_md">
					<h4 text="Call settings" />

					<!-- Ringer volume slider + live readout. -->
					<container width="100%" gap="#space_xs">
						<container width="100%" flow="row" style_flex_cross_place="center">
							<text text="Ringer volume" flex_grow="1" />
							<lv_label bind_text="subject_ringer_volume" bind_text-fmt="%d%%">
								<style name="style_text_accent" />
							</lv_label>
						</container>
						<slider subject="subject_ringer_volume" min="0" max="100" width="100%" />
					</container>

					<!-- Ring duration slider + live readout (seconds). -->
					<container width="100%" gap="#space_xs">
						<container width="100%" flow="row" style_flex_cross_place="center">
							<text text="Ring duration" flex_grow="1" />
							<lv_label bind_text="subject_ring_duration" bind_text-fmt="%d s">
								<style name="style_text_accent" />
							</lv_label>
						</container>
						<slider subject="subject_ring_duration" min="5" max="60" width="100%" />
					</container>

					<!-- Toggle rows packed into a list so they share dividers. -->
					<list width="100%">
						<list_item_switch
							title="Do not disturb"
							subtitle="Silence calls"
							subject="subject_do_not_disturb"
						/>
						<list_item_switch
							title="Show photos"
							subtitle="Display avatars"
							subject="subject_show_photos"
						/>
					</list>

					<!-- screen_load_event returns to the permanent home screen. -->
					<button text="Back" width="100%">
						<screen_load_event screen="screen_home" anim_type="over_right" duration="350" />
					</button>
				</panel>
			</container>
		</container>
	</view>
</screen>
