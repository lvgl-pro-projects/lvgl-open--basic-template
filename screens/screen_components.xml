<screen permanent="true">
	<view extends="lv_obj">
		<style name="style_screen_light" />
		<bind_style name="style_screen_dark" subject="subject_theme_dark" ref_value="1" />
		<style name="style_scrollbar" selector="scrollbar" />

		<column name="content" width="100%" height="content" pad="#space_lg" gap="#space_md">
			<row width="100%" gap="#space_md" vertical_align="center">
				<h5 text="Dark theme" />
				<container grow="1" />
				<switch subject="subject_theme_dark" />
			</row>

			<panel width="100%" gap="#space_sm">
				<h2 text="Heading 2" />
				<h3 text="Heading 3" />
				<h4 text="Heading 4" />
				<h5 text="Heading 5" />
				<text text="Body text. Give it a width and it wraps across the panel." width="100%" />
			</panel>

			<panel width="100%" gap="#space_sm">
				<h4 text="Buttons" />
				<row gap="#space_sm">
					<button text="Primary" />
					<button text="Add" icon="icon_plus" />
					<button text="Delete" icon="icon_trash" bg_color="#color_danger" />
				</row>
			</panel>

			<panel width="100%" gap="#space_md">
				<h4 text="Controls" />
				<slider subject="subject_brightness" width="100%" />
				<bar subject="subject_brightness" width="100%" />
				<row gap="#space_lg" vertical_align="center">
					<arc subject="subject_brightness">
						<lv_label align="center" bind_text="subject_brightness" bind_text-fmt="%d%%">
							<style name="style_text_accent" />
						</lv_label>
					</arc>
					<switch />
				</row>
			</panel>

			<panel width="100%" gap="#space_sm">
				<h4 text="Text inputs" />
				<text_input placeholder="Single line" width="100%" />
				<text_input placeholder="Password" password="true" width="100%" />
				<text_box placeholder="Multi-line text box" width="100%" />
			</panel>

			<panel width="100%" gap="#space_sm">
				<h4 text="Selection" />
				<dropdown options="Low&#10;Medium&#10;High" width="100%" />
				<checkbox text="Enable feature" />
				<checkbox text="Subscribe" />
			</panel>

			<list width="100%">
				<list_section text="List" />
				<list_item title="Simple item" />
				<list_item title="Simple item with icon" icon="icon_bell" />
				<list_item title="Turn me on!" icon="icon_edit">
					<list_item-trailing>
						<switch />
					</list_item-trailing>
				</list_item>
				<list_item title="Brightness" subtitle="Backlight" icon="icon_sun">
					<list_item-trailing>
						<lv_label bind_text="subject_brightness" bind_text-fmt="%d%%">
							<style name="style_text_accent" />
						</lv_label>
					</list_item-trailing>
				</list_item>
				<list_separator />
				<list_item title="About" subtitle="Version 1.0" icon="icon_info" />
			</list>
		</column>
	</view>
</screen>
