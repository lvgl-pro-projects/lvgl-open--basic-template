<component>
	<previews>
		<preview name="default" width="400" />
	</previews>

	<api>
		<prop name="text" type="string" default="Heading 5" help="Heading text" />
		<prop name="translation_tag" type="string" default="" help="Translation tag; overrides text when set" />
	</api>

	<!-- Smallest heading. Text color inherited; override per-use with style_text_color. -->
	<view extends="lv_label" text="$text" translation_tag="$translation_tag" style_text_font="font_h5" />
</component>
