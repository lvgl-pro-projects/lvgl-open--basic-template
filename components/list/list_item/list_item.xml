<component>
	<previews>
		<preview name="default" width="320" />
	</previews>

	<api>
		<prop name="title" type="string" default="Title" help="Primary text" />
		<prop
			name="subtitle"
			type="string"
			default=""
			help="Secondary text under the title (empty = just a blank line)"
		/>
		<!-- Left icon area. Fill with <list_item-icon><lv_image .../></list_item-icon>. -->
		<prop name="icon" type="image" default="" />
		<!-- Right area for a chevron, value label, switch, icon, etc.
		     Fill with <list_item-trailing>...</list_item-trailing>. -->
		<slot name="trailing" />
	</api>

	<!-- One list row: [icon] title / subtitle [trailing].
	     Uses the shared style_list_row (full width + divider) from globals. -->
	<view extends="container" flow="row" pad="#space_md" gap="#space_md">
		<style name="style_list_row" />

		<!-- slot target: left icon -->
		<lv_image name="icon_obj" src="$icon" hidden="{!icon}" />

		<!-- title + subtitle stacked, taking the remaining width -->
		<container grow="1" gap="#space_xs">
			<h5 text="$title" />
			<text text="$subtitle" hidden="{!subtitle}">
				<style name="style_text_muted" />
			</text>
		</container>

		<!-- slot target: trailing content -->
		<container name="trailing" flow="row" gap="#space_sm" />
	</view>
</component>
