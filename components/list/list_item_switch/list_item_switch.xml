<component>
	<previews>
		<preview name="default" width="320" />
	</previews>

	<api>
		<prop name="title" type="string" default="Setting" help="Primary text" />
		<prop name="subtitle" type="string" default="Subtitle" help="Secondary text under the title" />
		<prop name="hide_subtitle" type="bool" default="false" help="Hide the subtitle" />
		<prop
			name="subject"
			type="subject"
			default="subject_theme_dark"
			help="0/1 subject bound two-way to the switch"
		/>
	</api>

	<!-- A list row whose trailing control is a toggle bound to $subject.
	     Same divider/layout as list_item (shared style_list_row). -->
	<view extends="list_item" title="$title" subtitle="$subtitle">
		<list_item-trailing>
			<toggle subject="$subject" />
		</list_item-trailing>
	</view>
</component>
