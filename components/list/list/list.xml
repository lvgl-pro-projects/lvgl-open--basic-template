<component>
	<previews>
		<preview name="default" width="320" />
	</previews>

	<api>
		<prop name="pad" type="int" default="0" help="Inner padding around the rows (0 keeps rows full-width)" />
	</api>

	<!-- A panel that stacks list rows in a column. pad defaults to 0 so the
	     rows (and their dividers) span the full width; each row brings its
	     own padding. Drop list_section / list_item / list_item_switch /
	     list_separator children in at the use-site. -->
	<view extends="panel" pad="$pad" gap="0" />
</component>
