<component>
	<!-- Transparent, theme-free flex box for grouping children. Extends
	     base_box, so these locals apply after remove_style_all and stick.
	     Never set text_color here — let it inherit for free dark mode.
	     Use `panel` when you need a visible card surface. -->
	<api>
		<prop name="pad" type="int" default="8" help="Inner padding on all sides" />
		<prop name="gap" type="int" default="0" help="Space between children along the flow direction" />
		<prop name="flow" type="enum:lv_flex_flow" default="column" help="Child layout direction: column or row" />
		<prop
			name="grow"
			type="int"
			default="0"
			help="flex_grow when this box itself sits in a flex parent; NULL = natural size"
		/>
	</api>

	<view
		extends="base_box"
		flex_grow="$grow"
		style_pad_all="$pad"
		style_pad_row="$gap"
		style_pad_column="$gap"
		flex_flow="$flow"
	/>
</component>
