<component>
	<previews>
		<preview name="default" width="400" height="300" />
	</previews>

	<api>
		<prop name="title" type="string" default="Popup" help="Header title" />
		<prop name="modal" type="bool"   default="true"
		      help="true: the full-screen backdrop blocks clicks to the screen behind. false: clicks pass through and the background stays interactive. The dim itself is done by recoloring the screen content (see screen_components), not here." />
		<!-- Header action-button area (right of the title). -->
		<slot name="buttons" />
		<!-- Main content area. -->
		<slot name="content" />
		<!-- Footer button area (right-aligned). -->
		<slot name="footer" />
	</api>

	<styles>
		<!-- The centered dialog card -->
		<style name="style_dialog" width="60%" max_height="90%" />

		<!-- Header / footer dividers -->
		<style name="style_header" flex_cross_place="center"
		       border_side="bottom" border_width="#border_width" border_color="#color_track" border_opa="40%" />
		<style name="style_footer" flex_main_place="end" flex_cross_place="center"
		       border_side="top" border_width="#border_width" border_color="#color_track" border_opa="40%" />
	</styles>

	<!-- Full-screen, centered backdrop holding the dialog. `floating` lifts
	     it out of the parent's layout so it overlays any screen. It carries
	     NO dim of its own: a transparent backdrop can't tint what is behind
	     it, so recolor the screen's content instead (cheaper than a
	     translucent overlay). `clickable=$modal` makes it swallow background
	     clicks when modal, or pass them through when not. -->
	<view extends="base_box" width="100%" height="100%" floating="true" clickable="$modal"
	      style_flex_main_place="center" style_flex_cross_place="center">

		<!-- The dialog card. pad=0/gap=0 so the header/footer dividers span
		     full width; each region adds its own padding. -->
		<panel pad="0" gap="0">
			<style name="style_dialog" />

			<!-- Header: title + buttons slot -->
			<container width="100%" flow="row" pad="#space_md" gap="#space_sm">
				<style name="style_header" />
				<h4 text="$title" flex_grow="1" />
				<container name="buttons" flow="row" gap="#space_xs" />
			</container>

			<!-- Content slot -->
			<container name="content" width="100%" grow="1" pad="#space_md" gap="#space_sm" />

			<!-- Footer: right-aligned buttons slot -->
			<container width="100%" flow="row" pad="#space_md" gap="#space_sm">
				<style name="style_footer" />
				<container name="footer" flow="row" gap="#space_sm" />
			</container>
		</panel>
	</view>
</component>
