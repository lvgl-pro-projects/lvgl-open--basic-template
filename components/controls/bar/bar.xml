<component>
	<previews>
		<preview name="default" width="240" style_pad_all="20" />
	</previews>

	<api>
		<prop name="subject" type="subject" default="subject_brightness" help="Int subject the bar follows" />
		<prop name="min"     type="int"     default="0"    help="Lowest value" />
		<prop name="max"     type="int"     default="100"  help="Highest value" />
		<prop name="color"   type="color"   default="#color_accent" help="Filled indicator color" />
	</api>

	<!-- A read-only progress bar (no knob, not draggable) following $subject.
	     Neutral track on the main part; the fill takes $color. Set width at
	     the use-site. -->
	<styles>
		<style name="style_bar_track" bg_color="#color_track" bg_opa="35%" radius="#radius" />
	</styles>

	<view extends="lv_bar" width="200" height="14"
	      min_value="$min" max_value="$max" bind_value="$subject"
	      style_radius-indicator="#radius" style_bg_color-indicator="$color">
		<style name="style_bar_track" />
	</view>
</component>
