<component>
	<previews>
		<preview name="default" width="240" style_pad_all="20" />
	</previews>

	<api>
		<prop
			name="subject"
			type="subject"
			help="Int subject the slider reads and writes; drag it to change the subject"
		/>
		<prop name="min" type="int" default="0" help="Lowest value" />
		<prop name="max" type="int" default="100" help="Highest value" />
		<prop name="color" type="color" default="#color_accent" help="Filled indicator and knob color" />
	</api>

	<styles>
		<style name="style_slider_track" bg_color="#color_track" bg_opa="#opa_muted" radius="100" />
		<style name="style_slider_knob" radius="100" pad_all="#space_sm" />
	</styles>

	<!-- Two-way bound to $subject. Give it a width to stretch it. -->
	<view
		extends="lv_slider"
		width="200"
		height="#space_md"
		min_value="$min"
		max_value="$max"
		bind_value="$subject"
		style_bg_color-indicator="$color"
		style_bg_opa-indicator="100%"
		style_bg_color-knob="$color"
	>
		<style name="style_slider_track" />
		<style name="style_slider_track" selector="indicator" />
		<style name="style_slider_knob" selector="knob" />
	</view>
</component>
