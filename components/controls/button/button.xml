<component>
	<previews>
		<preview name="default" width="200" />
	</previews>

	<api>
		<prop name="text"       type="string" default="Button"             help="Button caption" />
		<prop name="bg_color"   type="color"  default="#color_accent"      help="Button background color" />
		<prop name="text_color" type="color"  default="#color_accent_text" help="Caption color" />
		<prop name="radius"     type="int"    default="#radius"            help="Corner radius" />
	</api>

	<!-- Static geometry. The caption color is inherited by the label child
	     from the button's $text_color local. -->
	<styles>
		<style name="style_button" pad_hor="#space_lg" pad_ver="#space_sm" />
	</styles>

	<!-- A button with a centered caption. Attach behavior at the use-site as
	     child events, e.g.:
	         <button text="Save"><event_cb callback="on_save" trigger="clicked"/></button>
	         <button text="Next"><screen_load_event screen="screen_two"/></button>
	     The $color props are locals so they stack on top of the theme; the
	     pressed state darkens via recolor. -->
	<view extends="lv_button"
	      style_bg_color="$bg_color" style_text_color="$text_color" style_radius="$radius"
	      style_recolor-pressed="0x000000" style_recolor_opa-pressed="25%">
		<style name="style_button" />
		<lv_label align="center" text="$text" />
	</view>
</component>
